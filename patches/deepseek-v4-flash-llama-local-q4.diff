+static bool ggml_moe_madvise_willneed_enabled(void) {
+    static int enabled = -1;
+    if (enabled < 0) {
+        const char * env = getenv("GGML_MOE_MADVISE_WILLNEED");
+        enabled = env != NULL && strcmp(env, "0") != 0 && strcmp(env, "false") != 0 && strcmp(env, "FALSE") != 0;
+    }
+    return enabled != 0;
+}
+
+static void ggml_moe_madvise_willneed_range(const void * ptr, size_t len) {
+#if !defined(_WIN32) && defined(MADV_WILLNEED)
+    if (ptr == NULL || len == 0) {
+        return;
+    }
+
+    long page_size = sysconf(_SC_PAGESIZE);
+    if (page_size <= 0) {
+        page_size = 4096;
+    }
+
+    const uintptr_t page_mask = (uintptr_t) page_size - 1;
+    const uintptr_t start = (uintptr_t) ptr & ~page_mask;
+    const uintptr_t end = ((uintptr_t) ptr + len + page_mask) & ~page_mask;
+    if (end > start) {
+        (void) madvise((void *) start, end - start, MADV_WILLNEED);
+    }
+#else
+    GGML_UNUSED(ptr);
+    GGML_UNUSED(len);
+#endif
+}
+
+static void ggml_moe_madvise_willneed_selected(
+        const struct ggml_tensor * src0,
+        const struct ggml_tensor * ids,
+        int64_t n_as,
+        size_t expert_stride) {
+    if (!ggml_moe_madvise_willneed_enabled() || src0->data == NULL || ids->data == NULL || n_as <= 0) {
+        return;
+    }
+
+    enum { GGML_MOE_MADVISE_STACK_EXPERTS = 1024 };
+    bool used_stack[GGML_MOE_MADVISE_STACK_EXPERTS];
+    bool * used = used_stack;
+    bool * used_heap = NULL;
+    if (n_as > GGML_MOE_MADVISE_STACK_EXPERTS) {
+        used_heap = (bool *) calloc(n_as, sizeof(bool));
+        if (used_heap == NULL) {
+            return;
+        }
+        used = used_heap;
+    } else {
+        memset(used, 0, sizeof(used_stack));
+    }
+
+    for (int64_t iid1 = 0; iid1 < ids->ne[1]; ++iid1) {
+        for (int64_t id = 0; id < ids->ne[0]; ++id) {
+            const int32_t i02 = *(const int32_t *) ((const char *) ids->data + iid1*ids->nb[1] + id*ids->nb[0]);
+            if (i02 >= 0 && i02 < n_as) {
+                used[i02] = true;
+            }
+        }
+    }
+
+    for (int64_t i = 0; i < n_as; ++i) {
+        if (used[i]) {
+            ggml_moe_madvise_willneed_range((const char *) src0->data + i*expert_stride, expert_stride);
+        }
+    }
+
+    free(used_heap);
+}
