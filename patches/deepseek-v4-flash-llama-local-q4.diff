+namespace {
+
+struct common_expert_trace_state {
+    std::ofstream        out;
+    std::vector<uint8_t> data;
+    std::mutex           mutex;
+    int64_t              start_us = 0;
+};
+
+static common_expert_trace_state g_expert_trace_state;
+
+static bool common_expert_trace_match(const ggml_tensor * t) {
+    if (t == nullptr || t->type != GGML_TYPE_I32) {
+        return false;
+    }
+
+    const char * name = ggml_get_name(t);
+    return std::strncmp(name, "ffn_moe_topk-", 13) == 0 ||
+           std::strncmp(name, "ffn_moe_hash_topk-", 18) == 0;
+}
+
+static int common_expert_trace_layer(const char * name) {
+    const char * dash = std::strrchr(name, '-');
+    if (dash == nullptr || dash[1] == '\0') {
+        return -1;
+    }
+    return std::atoi(dash + 1);
+}
+
+static bool common_expert_trace_cb_eval(ggml_tensor * t, bool ask, void * user_data) {
+    auto * state = static_cast<common_expert_trace_state *>(user_data);
+    if (ask) {
+        return common_expert_trace_match(t);
+    }
+
+    if (!common_expert_trace_match(t)) {
+        return true;
+    }
+
+    std::lock_guard<std::mutex> lock(state->mutex);
+    if (!state->out.is_open()) {
+        return true;
+    }
+
+    const size_t n_bytes = ggml_nbytes(t);
+    const bool is_host = ggml_backend_buffer_is_host(t->buffer);
+    const uint8_t * data = nullptr;
+    if (is_host) {
+        data = static_cast<const uint8_t *>(t->data);
+    } else {
+        state->data.resize(n_bytes);
+        ggml_backend_tensor_get(t, state->data.data(), 0, n_bytes);
+        data = state->data.data();
+    }
+
+    const char * name = ggml_get_name(t);
+    const int64_t n_expert_used = t->ne[0];
+    const int64_t n_tokens = t->ne[1];
+    const int64_t now_us = ggml_time_us();
+
+    state->out << "{\"event\":\"expert_topk\""
+               << ",\"t_us\":" << (now_us - state->start_us)
+               << ",\"tensor\":\"" << name << "\""
+               << ",\"layer\":" << common_expert_trace_layer(name)
+               << ",\"kind\":\"" << (std::strncmp(name, "ffn_moe_hash_topk-", 18) == 0 ? "hash" : "gate") << "\""
+               << ",\"n_expert_used\":" << n_expert_used
+               << ",\"n_tokens\":" << n_tokens
+               << ",\"experts\":[";
+
+    for (int64_t it = 0; it < n_tokens; ++it) {
+        if (it > 0) {
+            state->out << ',';
+        }
+        state->out << '[';
+        for (int64_t ie = 0; ie < n_expert_used; ++ie) {
+            if (ie > 0) {
+                state->out << ',';
+            }
+            const size_t off = it*t->nb[1] + ie*t->nb[0];
+            int32_t expert = 0;
+            std::memcpy(&expert, data + off, sizeof(expert));
+            state->out << expert;
+        }
+        state->out << ']';
+    }
+
+    state->out << "]}\n";
+    state->out.flush();
+    return true;
+}
+
+static void common_maybe_enable_expert_trace(common_params & params) {
+    const char * path = std::getenv("LLAMA_EXPERT_TRACE");
+    if (path == nullptr || path[0] == '\0') {
+        return;
+    }
+
+    if (params.cb_eval != nullptr && params.cb_eval != common_expert_trace_cb_eval) {
+        LOG_WRN("%s: LLAMA_EXPERT_TRACE ignored because another eval callback is already configured\n", __func__);
+        return;
+    }
+
+    std::lock_guard<std::mutex> lock(g_expert_trace_state.mutex);
+    if (!g_expert_trace_state.out.is_open()) {
+        g_expert_trace_state.out.open(path, std::ios::out | std::ios::trunc);
+        if (!g_expert_trace_state.out.is_open()) {
+            LOG_WRN("%s: failed to open LLAMA_EXPERT_TRACE path: %s\n", __func__, path);
+            return;
+        }
+        g_expert_trace_state.start_us = ggml_time_us();
+        LOG_INF("%s: writing MoE expert trace to %s\n", __func__, path);
+    }
+
+    params.cb_eval = common_expert_trace_cb_eval;
+    params.cb_eval_user_data = &g_expert_trace_state;
+}
+
+}
